{
  "name": "ackee-lighthouse",
  "version": "4.0.0",
  "private": true,
  "description": "Send Lighthouse reports to Ackee",
  "keywords": [
    "ackee",
    "tracking",
    "tracker",
    "report",
    "lighthouse",
    "chrome",
    "performance"
  ],
  "homepage": "https://github.com/electerious/ackee-lighthouse",
  "repository": {
    "type": "git",
    "url": "https://github.com/electerious/ackee-lighthouse.git"
  },
  "license": "MIT",
  "type": "module",
  "files": [
    "src"
  ],
  "scripts": {
    "eslint": "eslint \"**/*.js\"",
    "format": "npm run eslint -- --fix && npm run prettier -- --write",
    "lint": "npm run eslint && npm run prettier -- --check",
    "prettier": "prettier --ignore-path .gitignore \"**/*.{js,json,md,yml}\"",
    "start": "node --env-file-if-exists=.env src/index.js",
    "test": "npm run lint"
  },
  "dependencies": {
    "chrome-launcher": "^1.2.1",
    "dot-prop": "^10.1.0",
    "lighthouse": "^13.0.1",
    "signale": "^1.4.0"
  },
  "devDependencies": {
    "@electerious/eslint-config": "^5.2.1",
    "@electerious/prettier-config": "^4.0.0",
    "eslint": "^9.39.1",
    "prettier": "^3.6.2"
  },
  "authors": [
    "Tobias Reich <tobias@electerious.com>"
  ]
}
